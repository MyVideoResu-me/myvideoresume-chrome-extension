{
  "manifest_version": 3,
  "name": "hired.video - Recruiter",
  "version": "1.3",
  "description": "Recruiter Tools: Source candidates, extract profiles, match against jobs, manage talent pipeline. Powered by hired.video.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Click to Open Recruiter Panel"
  },
  "side_panel": {
    "default_path": "sidepanel-global.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "constants-recruiter.js",
        "content-script-jobs.js",
        "content-script-profiles.js",
        "content-script-companies.js"
      ]
    },
    {
      "matches": [
        "https://hired.video/*",
        "https://www.hired.video/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "auth-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
